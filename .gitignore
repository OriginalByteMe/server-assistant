.env
*.local.yaml
# local config holds secrets (token/chat); config.example.yaml is the template
/config.yaml
# per-user local harness settings
/.claude/settings.local.json
# ADR 0008 branch-out review artifacts (bundles + RESULT.json per run)
/tools/agent/out/
