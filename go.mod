module server-assistant

go 1.22

// Versions pinned to the Go 1.22 line (local toolchain). Newer releases of
// goose/modernc require Go >= 1.25; bump these only alongside a Go upgrade.
require (
	github.com/goccy/go-yaml v1.12.0
	github.com/pressly/goose/v3 v3.21.1
	github.com/stretchr/testify v1.9.0
	modernc.org/sqlite v1.33.1
)

require (
	github.com/davecgh/go-spew v1.1.1 // indirect
